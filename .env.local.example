# Vapi.ai API Key - https://dashboard.vapi.ai
VAPI_API_KEY=your_vapi_api_key_here

# Vapi Phone Number ID - Die Telefonnummer, die dem Agent zugewiesen wird
VAPI_PHONE_NUMBER_ID=your_phone_number_id_here

# Webhook Secret (optional) - Zum Verifizieren von Vapi Webhooks
VAPI_WEBHOOK_SECRET=your_webhook_secret_here

# Base URL for webhooks (set to your Vercel URL in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
